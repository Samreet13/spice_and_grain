<h1>Invoice</h1>

<p><strong>Order ID:</strong> <%= @order.id %></p>
<p><strong>Province:</strong> <%= @order.province.name %></p>
<h3>Products:</h3>

<ul>
  <% @order.order_items.each do |item| %>
    <li>
      <%= item.product.name %> -
      Qty: <%= item.quantity %> -
      $<%= number_with_precision(item.price, precision: 2) %>
    </li>
  <% end %>
</ul>
<p>Address: <%= current_customer.address %>, <%= current_customer.city %></p>
<p>Province: <%= current_customer.province&.name || "Not set" %></p>
<p>Subtotal: $<%= number_with_precision(@order.subtotal, precision: 2) %></p>

<p>GST: $<%= number_with_precision(@order.gst, precision: 2) %></p>

<% if @order.pst > 0 %>
  <p>PST: $<%= number_with_precision(@order.pst, precision: 2) %></p>
<% end %>

<% if @order.hst > 0 %>
  <p>HST: $<%= number_with_precision(@order.hst, precision: 2) %></p>
<% end %>

<h3>Total: $<%= number_with_precision(@order.total, precision: 2) %></h3>
<p><strong>Total Paid:</strong> $<%= @order.total.round(2) %></p>

<%= link_to "Back to Products", products_path, class: "btn btn-dark" %>