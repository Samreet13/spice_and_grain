<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Spice And Grain" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>

  <body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-dark bg-dark mb-4">
      <div class="container">
        <a class="navbar-brand" href="/">Spice & Grain</a>

        <div>
          <%= link_to "Products", products_path, class: "btn btn-light btn-sm" %>
          <%= link_to "Categories", categories_path, class: "btn btn-light btn-sm" %>
          <%= link_to "Admin", "/admin", class: "btn btn-warning btn-sm" %>

          <%= link_to "My Cart", cart_path, class: "btn btn-success" %>

          <%= link_to "About", page_path("About"), class: "btn btn-light btn-sm" %>
          <%= link_to "Contact", page_path("Contact"), class: "btn btn-light btn-sm" %>
          <% if admin_user_signed_in? %>
          <%= button_to "Logout", destroy_admin_user_session_path, method: :delete, class: "btn btn-danger btn-sm" %>
          <% end %>
          <% if customer_signed_in? %>
  <%= link_to "My Orders", orders_path, class: "btn btn-light" %>
  <%= link_to "Edit Profile", edit_customer_registration_path %>
  <%= button_to "Logout", destroy_customer_session_path, method: :delete, class: "btn btn-danger" %>
<% else %>
  <%= link_to "Sign Up", new_customer_registration_path, class: "btn btn-light" %>
  <%= link_to "Login", new_customer_session_path, class: "btn btn-light" %>
<% end %>
        </div>
      </div>
    </nav>

    <div class="container">

      <!-- FLASH MESSAGES -->
      <% if notice %>
        <div class="alert alert-success"><%= notice %></div>
      <% end %>

      <% if alert %>
        <div class="alert alert-danger"><%= alert %></div>
      <% end %>

      <%= yield %>

    </div>

  </body>
</html>