<p style="color: green"><%= notice %></p>
<!-- Product grid improvement -->
<!-- Product listing page with filters and search -->
<h1>Products</h1>

<%= form_with url: products_path, method: :get, local: true do %>
  <div class="row mb-3">

    <div class="col-md-5">
      <%= text_field_tag :search, params[:search],
        placeholder: "Search products...",
        class: "form-control" %>
    </div>

    <div class="col-md-4">
      <%= select_tag :category_id,
        options_from_collection_for_select(@categories, :id, :name, params[:category_id]),
        include_blank: "All Categories",
        class: "form-select" %>
    </div>

    <div class="col-md-3">
      <%= submit_tag "Search", class: "btn btn-dark w-100" %>
    </div>

  </div>
<% end %>
<!-- Product details UI improvement -->
<!-- Improved product listing UI -->
<p>
  <strong>Filter:</strong>
  <%= link_to "All", products_path %> |
  <% @categories.each do |category| %>
    <%= link_to category.name, products_path(category_id: category.id) %> |
  <% end %>
  <%= link_to "On Sale", products_path(on_sale: true) %> |
  <%= link_to "New", products_path(new: true) %> |
  <%= link_to "Updated", products_path(recent: true) %>
</p>

<div class="container">
  <div class="row">

    <% @products.each do |product| %>
      <div class="col-md-4 mb-4">
        <div class="card p-3 h-100">

          <!-- ✅ BADGES -->
          <div class="mb-2">
            <% if product.on_sale %>
              <span class="badge bg-success">On Sale</span>
            <% end %>

            <% if product.created_at >= 3.days.ago %>
              <span class="badge bg-primary">New</span>
            <% end %>

            <% if product.updated_at >= 3.days.ago && product.created_at < 3.days.ago %>
              <span class="badge bg-warning text-dark">Updated</span>
            <% end %>
          </div>

          <!-- ✅ IMAGE -->
          <% if product.image.attached? %>
            <%= image_tag product.image,
              class: "img-fluid mb-2",
              style: "height:150px; object-fit:cover;" %>
          <% end %>

          <!-- ✅ NAME -->
          <h2 class="card-title"><%= product.name %></h5>

          <!-- ✅ PRICE -->
          <p>
            Price:
            <% if product.on_sale %>
              <span style="text-decoration: line-through;">
                $<%= product.price %>
              </span>
              <strong class="text-success">$<%= product.sale_price %></strong>
            <% else %>
              $<%= product.price %>
            <% end %>
          </p>

          <p>Stock: <%= product.stock_quantity %></p>

          <!-- ✅ CATEGORIES -->
          <div class="mb-2">
            <% product.categories.each do |cat| %>
              <span class="badge bg-secondary"><%= cat.name %></span>
            <% end %>
          </div>

          <!-- ✅ BUTTONS -->
          <%= link_to "View", product, class: "btn btn-dark btn-sm" %>

<%= button_to "Add to Cart",
    add_to_cart_path(product),
    method: :post,
    class: "btn btn-success btn-sm mt-1" %>

<% if admin_user_signed_in? %>
  <%= link_to "Edit", edit_product_path(product), class: "btn btn-warning btn-sm" %>
  <%= link_to "Delete", product, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
<% end %>

        </div>
      </div>
    <% end %>

  </div>
</div>

<% if admin_user_signed_in? %>
  <%= link_to "New product", new_product_path, class: "btn btn-success mt-3" %>
<% end %>

<div class="mt-3">
  <%= paginate @products %>
</div>