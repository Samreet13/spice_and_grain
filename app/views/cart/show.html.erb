<h1>Your Cart</h1>

<% if @products.any? %>

  <% @products.each do |product| %>
    <div class="card p-3 mb-3">

      <h5><%= product.name %></h5>

      <p>Price: $<%= product.price %></p>

      <!-- UPDATE QUANTITY -->
      <%= form_with url: update_cart_path(product), method: :patch, local: true do %>
        <div class="d-flex align-items-center gap-2">
          <%= number_field_tag :quantity, @cart[product.id.to_s], min: 1, class: "form-control w-25" %>
          <%= submit_tag "Update", class: "btn btn-primary btn-sm" %>
        </div>
      <% end %>

      <!-- REMOVE BUTTON -->
      <%= button_to "Remove",
          remove_from_cart_path(product),
          method: :delete,
          class: "btn btn-danger btn-sm mt-2" %>

    </div>
  <% end %>

  <!-- ✅ CHECKOUT BUTTON (VERY IMPORTANT) -->
  <%= link_to "Proceed to Checkout",
      new_order_path,
      class: "btn btn-success mt-3" %>

<% else %>
  <p>Your cart is empty.</p>
<% end %>